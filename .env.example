# Server
PORT=8080
BASE_URL=https://s.example.com

# Admin
ADMIN_SECRET=change-me-to-a-strong-secret

# PostgreSQL
DATABASE_URL=postgres://shortener:shortener@localhost:5432/shortener?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Click counter
CLICK_BUFFER_SIZE=1000
CLICK_FLUSH_INTERVAL=5

# OG Scraper
OG_SCRAPE_TIMEOUT=5
OG_SCRAPE_MAX_BODY=1048576
